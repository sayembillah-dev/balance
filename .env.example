# ─── Balance instance config ──────────────────────────────────────────────
# Copy to `.env` and adjust. Only DATABASE_URL is strictly required for dev.

# Server
PORT=4000
NODE_ENV=development

# Database (Postgres). Dev: a Neon connection string works as-is.
# Self-host: points at the bundled `db` service, e.g.
#   postgres://balance:balance@db:5432/balance
DATABASE_URL=postgres://balance:balance@localhost:5432/balance

# Auth. If unset, the server generates a random secret into DATA_DIR on first
# boot (so it survives restarts). Set explicitly to share across replicas.
# JWT_SECRET=

# Where uploads + the generated JWT secret live (mounted as a volume in Docker).
DATA_DIR=./data

# Storage driver for uploads: `local` (default) or `s3` (added later).
STORAGE_DRIVER=local

# ─── First-admin bootstrap (optional) ─────────────────────────────────────
# If both are set AND no users exist yet, the first boot seeds this admin and
# skips the setup wizard. Leave blank to use the in-app first-run wizard.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# ─── Email / SMTP (optional) ──────────────────────────────────────────────
# Needed for password-reset + invite emails. Without it, reset/invite links are
# surfaced in the admin portal / server logs instead.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Balance <no-reply@example.com>"
